---
import { Image } from "astro:assets";
import logos from "../assets/original/logos.jpg";
import unterschrift from "../assets/original/unterschrift.gif";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "Baumeister Andreas Bauer – Allgemein beeideter und gerichtlich zertifizierter Sachverständiger",
    description = "Baumeister Andreas Bauer, Schärding – allgemein beeideter und gerichtlich zertifizierter Sachverständiger. Schulungen, Privat- und Gerichtsgutachten, begleitende Qualitätskontrolle und Beratung."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content={description}/>
    <meta name="generator" content={Astro.generator}/>
    <title>{title}</title>
    <base href={import.meta.env.BASE_URL}>
    <link rel="icon" type="image/vnd.microsoft.icon" href="favicon.ico"/>
    <link rel="apple-touch-icon" href="apple-touch-icon.png"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&display=swap"
          rel="stylesheet">
</head>
<body>

<a class="skip-link" href="#inhalt">Zum Inhalt springen</a>

<header class="site-header">
    <div class="container header-inner">
        <a class="brand" href={import.meta.env.BASE_URL}>
            <span class="brand-name">Baumeister Bauer</span>
            <span class="brand-sub">Gerichtlich zertifizierter Sachverständiger</span>
        </a>
        <button class="menu-btn" id="menu-btn" aria-label="Menü öffnen" aria-expanded="false" aria-controls="site-nav">
            <span></span><span></span>
        </button>
        <nav id="site-nav" class="site-nav">
            <ul>
                <li><a href={import.meta.env.BASE_URL}>Home</a></li>
                <li><a href="Schulungen">Schulungen</a></li>
                <li><a href="Gutachten">Gutachten</a></li>
                <li><a href="Qualitaetskontrolle">Qualitätskontrolle</a></li>
                <li><a href="Beratung">Beratung</a></li>
                <li><a href="Persoenliches">Persönliches</a></li>
                <li><a href="Kontakt" class="nav-cta">Kontakt</a></li>
            </ul>
        </nav>
    </div>
</header>

<main id="inhalt">
    <slot/>
</main>

<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col footer-ident">
                <Image src={unterschrift} alt="Unterschrift Andreas Bauer" class="footer-signature" width={240}/>
                <p class="footer-title">Baumeister Andreas Bauer</p>
                <p class="footer-muted">Allgemein beeideter und gerichtlich<br/>zertifizierter Sachverständiger</p>
                <Image src={logos} alt="Gütezeichen Baumeister und Gerichtssachverständige" class="footer-badges" width={200}/>
            </div>
            <div class="footer-col">
                <h3>Kontakt</h3>
                <p>Unterer Richtstattweg 7A<br/>4780 Schärding</p>
                <p><a href="tel:+4369914245060">+43/699/142 450 60</a><br/>
                    <a href="mailto:info@baumeister-bauer.at">info@baumeister-bauer.at</a></p>
            </div>
            <div class="footer-col">
                <h3>Leistungen</h3>
                <ul>
                    <li><a href="Schulungen">Vorträge und Schulungen</a></li>
                    <li><a href="Gutachten">Privat- u. Gerichtsgutachten</a></li>
                    <li><a href="Qualitaetskontrolle">Begleitende Qualitätskontrolle</a></li>
                    <li><a href="Beratung">Beratung</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h3>Rechtliches</h3>
                <ul>
                    <li><a href="Impressum">Impressum &amp; Datenschutz</a></li>
                    <li><a href="AGB.pdf" target="_blank" rel="noopener noreferrer">AGB (PDF)</a></li>
                    <li><a href="Honorarsaetze2025.pdf" target="_blank" rel="noopener noreferrer">Honorarsätze (PDF)</a></li>
                    <li><a href="Information_und_Aufklrung_FAGG.pdf" target="_blank" rel="noopener noreferrer">Info gemäß FAGG (PDF)</a></li>
                    <li><a href="Muster-Widerrufsformular.pdf" target="_blank" rel="noopener noreferrer">Muster-Widerrufsformular (PDF)</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© {new Date().getFullYear()} Baumeister Andreas Bauer · 4780 Schärding</p>
        </div>
    </div>
</footer>

</body>
</html>

<style is:global>
    :root {
        --paper: #f4f1ea;
        --paper-raised: #fbf9f4;
        --paper-deep: #eae5d9;
        --ink: #211e19;
        --ink-soft: #5d574b;
        --line: #d9d2c2;
        --line-strong: #b6ad99;
        --oxide: #9d3b26;
        --oxide-deep: #7e2e1c;
        --anthracite: #25221d;
        --anthracite-deep: #1d1b17;
        --font-display: 'Archivo', 'Helvetica Neue', sans-serif;
        --font-body: 'Source Serif 4', Georgia, serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    html, body {
        overflow-x: clip;
    }

    body {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.7;
        color: var(--ink);
        background-color: var(--paper);
    }

    img {
        max-width: 100%;
        height: auto;
        display: block;
    }

    h1, h2, h3, h4 {
        font-family: var(--font-display);
        font-stretch: 112%;
        font-weight: 700;
        line-height: 1.12;
        letter-spacing: -0.015em;
        color: var(--ink);
        text-wrap: balance;
    }

    ::selection {
        background: var(--oxide);
        color: var(--paper);
    }

    .container {
        width: min(100% - 3rem, 1140px);
        margin-inline: auto;
    }

    /* ---- shared building blocks ---- */
    .overline {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--oxide);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .overline::before {
        content: "";
        width: 2rem;
        height: 1px;
        background: var(--oxide);
        flex: none;
    }

    .lead {
        font-size: 1.25rem;
        line-height: 1.6;
        color: var(--ink-soft);
        max-width: 60ch;
    }

    .btn {
        display: inline-block;
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
        padding: 0.9rem 1.8rem;
        border: 1px solid var(--ink);
        background: var(--ink);
        color: var(--paper);
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }

    .btn:hover {
        background: var(--oxide);
        border-color: var(--oxide);
        color: #fff;
    }

    .btn.btn-outline {
        background: transparent;
        color: var(--ink);
    }

    .btn.btn-outline:hover {
        background: var(--ink);
        color: var(--paper);
    }

    .duotone {
        object-fit: cover;
        width: 100%;
        height: 100%;
    }

    /* offset oxide frame behind images */
    .framed {
        position: relative;
    }

    .framed::after {
        content: "";
        position: absolute;
        inset: 1rem -1rem -1rem 1rem;
        border: 1px solid var(--oxide);
        z-index: -1;
    }

    /* shared page intro for subpages */
    .page-hero {
        padding: 5rem 0 3.5rem;
        border-bottom: 1px solid var(--line);
    }

    .page-hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        margin: 1.2rem 0 1.4rem;
        max-width: 18ch;
    }

    .section {
        padding: 5rem 0;
    }

    .section + .section {
        padding-top: 0;
    }

    .section-rule {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 0;
    }

    /* numbered fact list used on several pages */
    .fact-list {
        list-style: none;
        counter-reset: fakten;
        border-top: 1px solid var(--line);
    }

    .fact-list li {
        counter-increment: fakten;
        display: grid;
        grid-template-columns: 3.5rem 1fr;
        gap: 1.25rem;
        align-items: baseline;
        padding: 1.1rem 0;
        border-bottom: 1px solid var(--line);
    }

    .fact-list li::before {
        content: counter(fakten, decimal-leading-zero);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--oxide);
        letter-spacing: 0.05em;
    }

    /* dark closing band with contact prompt, reused by pages */
    .cta-band {
        background: var(--anthracite);
        color: var(--paper);
        padding: 4.5rem 0;
    }

    .cta-band .overline {
        color: var(--paper-deep);
    }

    .cta-band .overline::before {
        background: var(--oxide);
    }

    .cta-band h2 {
        color: var(--paper-raised);
        font-size: clamp(1.7rem, 3.5vw, 2.4rem);
        margin: 1rem 0 0.75rem;
        max-width: 24ch;
    }

    .cta-band p {
        color: rgba(244, 241, 234, 0.75);
        max-width: 55ch;
        margin-bottom: 2rem;
    }

    .cta-band .btn {
        background: var(--oxide);
        border-color: var(--oxide);
        color: #fff;
    }

    .cta-band .btn:hover {
        background: var(--oxide-deep);
        border-color: var(--oxide-deep);
    }

    /* ---- header ---- */
    .skip-link {
        position: absolute;
        left: -200vw;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.5rem 1rem;
        z-index: 2000;
    }

    .skip-link:focus {
        left: 0;
    }

    .site-header {
        background: var(--paper);
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding: 1.1rem 0;
    }

    .brand {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .brand-name {
        font-family: var(--font-display);
        font-stretch: 115%;
        font-weight: 800;
        font-size: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--ink);
    }

    .brand-sub {
        font-family: var(--font-display);
        font-size: 0.66rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--oxide);
        margin-top: 0.15rem;
    }

    .site-nav ul {
        display: flex;
        align-items: center;
        gap: 1.6rem;
        list-style: none;
    }

    .site-nav a {
        font-family: var(--font-display);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        text-decoration: none;
        color: var(--ink);
        padding: 0.4rem 0;
        border-bottom: 2px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    .site-nav a:hover {
        color: var(--oxide);
    }

    .site-nav a.current {
        border-bottom-color: var(--oxide);
        color: var(--oxide);
    }

    .site-nav a.nav-cta {
        border: 1px solid var(--ink);
        padding: 0.55rem 1.1rem;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .site-nav a.nav-cta:hover,
    .site-nav a.nav-cta.current {
        background: var(--ink);
        color: var(--paper);
    }

    .menu-btn {
        display: none;
        background: none;
        border: 0;
        cursor: pointer;
        padding: 0.75rem 0.25rem;
        z-index: 1101;
    }

    .menu-btn span {
        display: block;
        width: 26px;
        height: 2px;
        background: var(--ink);
        margin: 6px 0;
        transition: transform 0.25s ease, opacity 0.25s ease;
    }

    body.nav-open .menu-btn span:first-child {
        transform: translateY(4px) rotate(45deg);
    }

    body.nav-open .menu-btn span:last-child {
        transform: translateY(-4px) rotate(-45deg);
    }

    /* ---- footer ---- */
    .site-footer {
        background: var(--anthracite-deep);
        color: var(--paper-deep);
        margin-top: 0;
        padding: 4rem 0 2rem;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 2.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(244, 241, 234, 0.15);
    }

    .footer-col h3 {
        color: var(--paper-raised);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        margin-bottom: 1.1rem;
    }

    .footer-col p {
        margin-bottom: 0.9rem;
        font-size: 0.95rem;
        color: rgba(244, 241, 234, 0.75);
    }

    .footer-col ul {
        list-style: none;
    }

    .footer-col ul li {
        margin-bottom: 0.55rem;
    }

    .footer-col a {
        color: rgba(244, 241, 234, 0.75);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s ease;
    }

    .footer-col a:hover {
        color: #fff;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .footer-signature {
        width: 200px;
        height: auto;
        margin-bottom: 1rem;
    }

    .footer-title {
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--paper-raised) !important;
        margin-bottom: 0.2rem !important;
    }

    .footer-muted {
        font-size: 0.88rem !important;
    }

    .footer-badges {
        width: 160px;
        height: auto;
        margin-top: 1.25rem;
        opacity: 0.85;
    }

    .footer-bottom {
        padding-top: 1.5rem;
        font-family: var(--font-display);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        color: rgba(244, 241, 234, 0.5);
    }

    /* ---- responsive ---- */
    @media (max-width: 980px) {
        .menu-btn {
            display: block;
        }

        .site-nav {
            position: fixed;
            inset: 0;
            background: var(--paper);
            transform: translateX(100%);
            transition: transform 0.3s ease;
            z-index: 1100;
            display: grid;
            place-items: center;
        }

        body.nav-open .site-nav {
            transform: translateX(0);
        }

        body.nav-open {
            overflow: hidden;
        }

        body.nav-open .menu-btn {
            position: fixed;
            top: 1.1rem;
            right: 1.5rem;
        }

        .site-nav ul {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }

        .site-nav a {
            font-size: 1.05rem;
        }

        .footer-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 560px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.getElementById('menu-btn');
        const nav = document.getElementById('site-nav');

        if (menuBtn && nav) {
            menuBtn.addEventListener('click', () => {
                const open = document.body.classList.toggle('nav-open');
                menuBtn.setAttribute('aria-expanded', String(open));
                menuBtn.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
            });

            nav.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    document.body.classList.remove('nav-open');
                    menuBtn.setAttribute('aria-expanded', 'false');
                });
            });
        }

        // mark current page in navigation (respects <base>)
        const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
        document.querySelectorAll('.site-nav a').forEach(item => {
            const itemPath = (item as HTMLAnchorElement).pathname.replace(/\/$/, '') || '/';
            if (itemPath === currentPath) {
                item.classList.add('current');
            }
        });
    });
</script>
