---
import { Image } from "astro:assets";
import gutachten from "../assets/original/gutachten2.jpg";
import schulung from "../assets/original/Schulung.jpg";
import qualitaet from "../assets/original/Qualitaetskontrolle_kl.jpg";
import beratung from "../assets/original/Beratung2.jpg";
import portrait from "../assets/original/andreas_bauer.jpg";

const leistungen = [
    {
        titel: "Vorträge und Schulungen",
        link: "Schulungen",
        bild: schulung,
        alt: "Andreas Bauer bei einem Vortrag vor Publikum",
        text: "Vorträge für Systemhalter und Schulungen für WDVS-Firmen – von den bauphysikalischen Grundlagen bis zur normgerechten Ausführung."
    },
    {
        titel: "Privat- u. Gerichtsgutachten",
        link: "Gutachten",
        bild: gutachten,
        alt: "Andreas Bauer vor dem Landesgericht Ried im Innkreis",
        text: "Privatgutachten zur Beurteilung der technischen Ausführung sowie Gerichtsgutachten im Auftrag von Richtern und Staatsanwälten."
    },
    {
        titel: "Begleitende Qualitätskontrolle",
        link: "Qualitaetskontrolle",
        bild: qualitaet,
        alt: "Andreas Bauer bei der Kontrolle eines Wärmedämmverbundsystems",
        text: "Laufende Kontrolle der Ausführung auf der Baustelle – Mängel beim WDVS werden so auf ein Minimum reduziert."
    },
    {
        titel: "Beratung",
        link: "Beratung",
        bild: beratung,
        alt: "Andreas Bauer im Beratungsgespräch",
        text: "Beratungsgespräche zu Ihren Anliegen sowie Unterstützung von Planern und ausführenden Firmen in der Detailplanung."
    }
];
---

<section class="hero">
    <div class="container hero-grid">
        <div class="hero-text">
            <p class="overline">Allgemein beeideter und gerichtlich zertifizierter Sachverständiger</p>
            <h1>Baumeister<br/>Andreas Bauer</h1>
            <p class="lead">Auf Grund meiner jahrelangen Erfahrung biete ich Ihnen neutrale, fachliche und kompetente
                Beratung.</p>
            <div class="hero-cta">
                <a href="Kontakt" class="btn">Kontakt aufnehmen</a>
                <a href="#leistungen" class="btn btn-outline">Leistungen</a>
            </div>
        </div>
        <div class="hero-media framed">
            <Image src={gutachten} alt="Baumeister Andreas Bauer vor dem Landesgericht Ried im Innkreis" class="duotone" widths={[480, 800]} sizes="(max-width: 860px) 100vw, 520px"/>
        </div>
    </div>
</section>

<section class="cred-band">
    <div class="container">
        <p class="cred-heading">Experte in den Fachgremien</p>
        <ul class="cred-grid">
            <li>
                <span class="cred-org">Austrian Standards</span>
                <span class="cred-detail">AG 166.02 – Außenwand-Wärmedämmverbundsysteme</span>
            </li>
            <li>
                <span class="cred-org">Austrian Standards</span>
                <span class="cred-detail">AG 207.02 – Estriche sowie Putz- und Mauermörtel</span>
            </li>
            <li>
                <span class="cred-org">ÖAP</span>
                <span class="cred-detail">Österreichische Arbeitsgemeinschaft Putz</span>
            </li>
            <li>
                <span class="cred-org">ARGE Fensterbank</span>
                <span class="cred-detail">Experte der Arbeitsgemeinschaft</span>
            </li>
        </ul>
    </div>
</section>

<section class="section" id="leistungen">
    <div class="container">
        <p class="overline">Leistungen</p>
        <h2 class="section-title">Vier Bereiche, ein Anspruch:<br/>neutral und fachlich fundiert.</h2>
        <div class="service-grid">
            {leistungen.map((l, i) => (
                <a href={l.link} class="service-card">
                    <div class="service-media">
                        <Image src={l.bild} alt={l.alt} class="duotone" widths={[420, 720]} sizes="(max-width: 700px) 100vw, 520px"/>
                    </div>
                    <div class="service-body">
                        <span class="service-index">{String(i + 1).padStart(2, "0")}</span>
                        <h3>{l.titel}</h3>
                        <p>{l.text}</p>
                        <span class="service-more">Mehr erfahren</span>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<hr class="section-rule"/>

<section class="section about">
    <div class="container about-grid">
        <div class="about-media framed">
            <Image src={portrait} alt="Porträt Baumeister Andreas Bauer" class="duotone" width={420}/>
        </div>
        <div class="about-text">
            <p class="overline">Persönliches</p>
            <h2>Vom Maurerlehrling zum gerichtlich zertifizierten Sachverständigen</h2>
            <p>Maurerlehre, Maurermeister, Bauleiter und Spartenleiter für Wärmedämmverbundsysteme, Baumeister – und
                seit 2015 allgemein beeideter und gerichtlich zertifizierter Sachverständiger für die Herstellung von
                Wärmedämmverbundsystemen.</p>
            <a href="Persoenliches" class="btn btn-outline">Mein Werdegang</a>
        </div>
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <p class="overline">Kontakt</p>
        <h2>Für Anfragen stehe ich Ihnen gerne zur Verfügung.</h2>
        <p>Unterer Richtstattweg 7A, 4780 Schärding · +43/699/142 450 60 · info@baumeister-bauer.at</p>
        <a href="Kontakt" class="btn">Kontakt aufnehmen</a>
    </div>
</section>

<style>
    /* hero */
    .hero {
        padding: 5.5rem 0 5rem;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 4rem;
        align-items: center;
    }

    .hero h1 {
        font-size: clamp(2.1rem, 6vw, 4.2rem);
        font-stretch: 118%;
        font-weight: 800;
        text-transform: uppercase;
        margin: 1.4rem 0 1.6rem;
    }

    .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2.4rem;
    }

    .hero-media :global(img) {
        aspect-ratio: 4 / 3;
    }

    /* credential band */
    .cred-band {
        background: var(--anthracite);
        color: var(--paper-deep);
        padding: 3rem 0;
    }

    .cred-heading {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: rgba(244, 241, 234, 0.55);
        margin-bottom: 1.75rem;
    }

    .cred-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
    }

    .cred-grid li {
        border-left: 1px solid var(--oxide);
        padding-left: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .cred-org {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1rem;
        color: var(--paper-raised);
    }

    .cred-detail {
        font-size: 0.9rem;
        line-height: 1.5;
        color: rgba(244, 241, 234, 0.7);
    }

    /* services */
    .section-title {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        margin: 1.2rem 0 3rem;
        max-width: 26ch;
    }

    .service-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
    }

    .service-card {
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--line);
        background: var(--paper-raised);
        display: flex;
        flex-direction: column;
        transition: border-color 0.25s ease;
    }

    .service-card:hover {
        border-color: var(--oxide);
    }

    .service-media {
        overflow: hidden;
        aspect-ratio: 16 / 9;
        border-bottom: 1px solid var(--line);
    }

    .service-media :global(img) {
        transition: transform 0.5s ease;
    }

    .service-card:hover .service-media :global(img) {
        transform: scale(1.04);
    }

    .service-body {
        padding: 1.75rem 1.75rem 2rem;
        position: relative;
    }

    .service-index {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--oxide);
        letter-spacing: 0.08em;
    }

    .service-body h3 {
        font-size: 1.3rem;
        margin: 0.5rem 0 0.75rem;
    }

    .service-body p {
        color: var(--ink-soft);
        font-size: 0.98rem;
        margin-bottom: 1.4rem;
    }

    .service-more {
        font-family: var(--font-display);
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink);
        border-bottom: 2px solid var(--oxide);
        padding-bottom: 0.2rem;
        transition: color 0.2s ease;
    }

    .service-card:hover .service-more {
        color: var(--oxide);
    }

    /* about */
    .about {
        padding-top: 5rem;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 0.55fr 1fr;
        gap: 4.5rem;
        align-items: center;
    }

    .about-media {
        max-width: 340px;
    }

    .about-text h2 {
        font-size: clamp(1.7rem, 3.5vw, 2.4rem);
        margin: 1.2rem 0 1.2rem;
        max-width: 22ch;
    }

    .about-text p {
        color: var(--ink-soft);
        max-width: 58ch;
        margin-bottom: 2rem;
    }

    /* responsive */
    @media (max-width: 980px) {
        .cred-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 860px) {
        .hero {
            padding: 3.5rem 0 4rem;
        }

        .hero-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .hero-media {
            margin-right: 1rem;
        }

        .about-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }

    @media (max-width: 700px) {
        .service-grid {
            grid-template-columns: 1fr;
            gap: 1.75rem;
        }

        .cred-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
    }
</style>
