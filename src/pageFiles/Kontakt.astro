        <div class="contact-block">
            <h2>Telefon</h2>
            <p><a class="contact-big" href="tel:+4369914245060">+43/699/142 450 60</a></p>
            <h2 class="second">E-Mail</h2>
            <p><a class="contact-big" href="mailto:info@baumeister-bauer.at">info@baumeister-bauer.at</a></p>
