<section class="cta-band">
    <div class="container">
        <p class="overline">Direkt schreiben</p>
        <h2>Schildern Sie mir Ihr Anliegen per E-Mail.</h2>
        <p>Ich melde mich so rasch wie möglich bei Ihnen.</p>
        <a href="mailto:info@baumeister-bauer.at" class="btn">E-Mail verfassen</a>
    </div>
</section>

<style>
    .contact-section {
        padding-top: 4.5rem;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2.5rem;
    }

    .contact-block {
        border: 1px solid var(--line);
        background: var(--paper-raised);
        padding: 2.25rem;
    }

    .contact-block h2 {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--oxide);
        margin-bottom: 1rem;
    }

    .contact-block h2.second {
        margin-top: 2rem;
    }

    .contact-block p {
        color: var(--ink-soft);
        margin-bottom: 1.25rem;
    }

    .contact-big {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--oxide);
        padding-bottom: 0.15rem;
        transition: color 0.2s ease;
        word-break: break-word;
    }

    .contact-big:hover {
        color: var(--oxide);
    }

    .contact-link {
        font-family: var(--font-display);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--oxide);
        padding-bottom: 0.2rem;
        transition: color 0.2s ease;
    }

    .contact-link:hover {
        color: var(--oxide);
    }

    .doc-list {
        list-style: none;
    }

    .doc-list li {
        border-bottom: 1px solid var(--line);
        padding: 0.7rem 0;
    }

    .doc-list li:first-child {
        border-top: 1px solid var(--line);
    }

    .doc-list a {
        color: var(--ink);
        text-decoration: none;
        font-size: 0.97rem;
        transition: color 0.2s ease;
    }

    .doc-list a:hover {
        color: var(--oxide);
    }

    @media (max-width: 980px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 1.75rem;
        }
    }
</style>
