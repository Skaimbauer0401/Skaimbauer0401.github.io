---
import { Image } from "astro:assets";
import portrait from "../assets/original/andreas_bauer.jpg";
import unterschrift from "../assets/original/unterschrift.gif";

const werdegang = [
    {
        zeit: "1990–1993",
        titel: "Maurerlehre",
        text: "Maurerlehre bei der Firma Ferro-Betonit-Werke in Schärding (Abschluss mit Auszeichnung). Anschließende Tätigkeit als Maurervorarbeiter auf Großbaustellen in Oberösterreich und Wien."
    },
    {
        zeit: "1995",
        titel: "Weiterbildung zum Maurermeister",
        text: "Beginn der dreijährigen berufsbegleitenden Weiterbildung zum Maurermeister an der Bauhandwerkerschule in der HTL Bau in Linz (erfolgreicher Abschluss 1998)."
    },
    {
        zeit: "1996",
        titel: "Maurerpolier und Hochbauzeichner",
        text: "Wechsel zur Firma Bortenschlager in Ried im Innkreis (Maurerpolier). Ausbildung zum Hochbauzeichner (ArchiCAD am WIFI in Linz)."
    },
    {
        zeit: "2003",
        titel: "Bauleiter für Wärmedämmverbundsysteme",
        text: "Firmenwechsel zur Firma Moser Fertigputz in Raab als Bauleiter für Wärmedämmverbundsysteme."
    },
    {
        zeit: "Ab 2006",
        titel: "Spartenleiter",
        text: "Spartenleiter für Wärmedämmverbundsysteme."
    },
    {
        zeit: "August 2010",
        titel: "Baumeisterschule",
        text: "Beginn der Baumeisterschule in Ried im Innkreis (berufsbegleitend)."
    },
    {
        zeit: "März 2012",
        titel: "Befähigungsprüfung Baumeister",
        text: "Erfolgreicher Abschluss der Befähigungsprüfung zum Gewerbe Baumeister."
    },
    {
        zeit: "August 2012",
        titel: "Firmengründung",
        text: "Firmengründung Architekturbüro Baumeister Andreas Bauer e.U."
    },
    {
        zeit: "2013",
        titel: "Experte der ÖAP",
        text: "Experte in der ÖAP (Österreichische Arbeitsgemeinschaft Putz). Mitautor diverser Richtlinien: RL Sockel, RL Oberputz, RL Anputzleisten, usw."
    },
    {
        zeit: "2014",
        titel: "Austrian Standards",
        text: "Experte von Austrian Standards (Normungsinstitut), ON-AG 166.02 Wärmedämmverbundsysteme."
    },
    {
        zeit: "2015",
        titel: "Gerichtssachverständiger",
        text: "Allgemein beeideter und gerichtlich zertifizierter Sachverständiger für die Herstellung von Wärmedämmverbundsystemen."
    },
    {
        zeit: "2016",
        titel: "Austrian Standards",
        text: "Experte von Austrian Standards (Normungsinstitut), ON-AG 207.02 Estriche sowie Putz- und Mauermörtel."
    },
    {
        zeit: "2019",
        titel: "ARGE Fensterbank",
        text: "Experte der ARGE Fensterbank."
    }
];
---

<section class="page-hero">
    <div class="container hero-grid">
        <div>
            <p class="overline">Persönliches</p>
            <h1>Baumeister Andreas Bauer</h1>
            <p class="lead">Allgemein beeideter und gerichtlich zertifizierter Sachverständiger – über 30 Jahre am Bau,
                vom Maurerlehrling bis zum Experten in den österreichischen Normungsgremien.</p>
        </div>
        <div class="hero-media framed">
            <Image src={portrait} alt="Porträt Baumeister Andreas Bauer" class="duotone" width={420}/>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="timeline-heading">Beruflicher Werdegang</h2>
        <ol class="timeline">
            {werdegang.map((station) => (
                <li>
                    <span class="timeline-date">{station.zeit}</span>
                    <div class="timeline-body">
                        <h3>{station.titel}</h3>
                        <p>{station.text}</p>
                    </div>
                </li>
            ))}
        </ol>
    </div>
</section>

<section class="signature-band">
    <div class="container signature-inner">
        <Image src={unterschrift} alt="Unterschrift Andreas Bauer" width={280}/>
        <p>Baumeister Andreas Bauer<br/><span>Allgemein beeideter und gerichtlich zertifizierter Sachverständiger</span></p>
    </div>
</section>

<style>
    .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 4rem;
        align-items: center;
    }

    .hero-media {
        max-width: 300px;
        justify-self: end;
    }

    /* timeline */
    .timeline-heading {
        font-size: clamp(1.7rem, 3.5vw, 2.2rem);
        margin: 4.5rem 0 3rem;
    }

    .timeline {
        list-style: none;
        border-left: 1px solid var(--line-strong);
        margin-left: 0.25rem;
    }

    .timeline li {
        display: grid;
        grid-template-columns: 9rem 1fr;
        gap: 2rem;
        padding: 0 0 2.75rem 2rem;
        position: relative;
    }

    .timeline li::before {
        content: "";
        position: absolute;
        left: -0.32rem;
        top: 0.5em;
        width: 0.6rem;
        height: 0.6rem;
        background: var(--paper);
        border: 1px solid var(--oxide);
        transform: rotate(45deg);
    }

    .timeline li:last-child {
        padding-bottom: 0.5rem;
    }

    .timeline-date {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        color: var(--oxide);
        white-space: nowrap;
    }

    .timeline-body h3 {
        font-size: 1.15rem;
        margin-bottom: 0.4rem;
    }

    .timeline-body p {
        color: var(--ink-soft);
        max-width: 62ch;
    }

    /* signature band */
    .signature-band {
        background: var(--anthracite);
        padding: 4rem 0;
        margin-top: 5rem;
    }

    .signature-inner {
        display: flex;
        align-items: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .signature-inner p {
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--paper-raised);
        line-height: 1.5;
    }

    .signature-inner p span {
        font-weight: 400;
        font-size: 0.85rem;
        color: rgba(244, 241, 234, 0.65);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    @media (max-width: 860px) {
        .hero-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .hero-media {
            justify-self: start;
            margin-right: 1rem;
        }

        .timeline li {
            grid-template-columns: 1fr;
            gap: 0.4rem;
        }
    }
</style>
