---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 – Seite nicht gefunden | Baumeister Andreas Bauer">
    <section class="notfound">
        <div class="container">
            <p class="overline">Fehler 404</p>
            <h1>Diese Seite wurde nicht gefunden.</h1>
            <p class="lead">Die angeforderte Seite existiert nicht oder wurde verschoben.</p>
            <a href={import.meta.env.BASE_URL} class="btn">Zur Startseite</a>
        </div>
    </section>
</Layout>

<style>
    .notfound {
        padding: 7rem 0 8rem;
    }

    .notfound h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        margin: 1.2rem 0 1rem;
    }

    .notfound .lead {
        margin-bottom: 2.5rem;
    }
</style>
